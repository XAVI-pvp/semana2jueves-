Algoritmo Suma_Resta
    Definir numero1, numero2, suma, resta Como Real
    
    Escribir "Primer número:"
    Leer num1
    Escribir "Segundo número:"
    Leer numero2
    
    suma <- num1 + num2
    resta <- numero1 - numero2
    
    Escribir "Suma: ", suma
    Escribir "Resta: ", resta
FinAlgoritmo
